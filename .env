# Next.js + Prisma + Stripe + NextAuth template env vars
# Required for all environments

DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_SECRET="$(openssl rand -base64 32)"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (create account at stripe.com)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (use resend.com or similar)
RESEND_API_KEY=""

# PRISMA
DIRECT_URL="file:./prisma/dev.db"

# Optional OAuth (facebook.com/developers, developers.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

