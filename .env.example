# NEXT AUTH CONFIGURATION
NEXTAUTH_SECRET="your-generated-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# DATABASE CONFIGURATION
DATABASE_URL="postgresql://user:password@localhost:5432/dropler"
DIRECT_URL="postgresql://user:password@localhost:5432/dropler"

# STRIPE CONFIGURATION (Optional but required for payment processing)
STRIPE_SECRET_KEY="sk_test_your_stripe_test_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# STRIPE SUBSCRIPTION PRICE IDs
NEXT_PUBLIC_STRIPE_PRICE_STARTER="price_xxx"
NEXT_PUBLIC_STRIPE_PRICE_PRO="price_xxx"
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE="price_xxx"

# GOOGLE OAUTH (Optional)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# FACEBOOK OAUTH (Optional)
FACEBOOK_CLIENT_ID="your-facebook-app-id"
FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# EMAIL SERVICE (Optional but recommended)
RESEND_API_KEY="re_your_resend_api_key"

# NODE ENVIRONMENT
NODE_ENV="development"

# =====================================================
# HOW TO USE:
# =====================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in actual values (never commit .env or .env.local)
# 3. For production, set these in your deployment platform
#    (Vercel, Docker, CI/CD secrets, etc.)
#
# SECURITY NOTES:
# - NEVER commit .env or .env.local to version control
# - NEVER share credentials with others
# - ALWAYS rotate credentials if they're exposed
# - Use strong NEXTAUTH_SECRET: generate with: openssl rand -base64 32
